<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.gz.biz.demo.mapper.BizDemoMapper">

    <resultMap type="BizDemoDO" id="BizDemoResult">
        <result property="id" column="id"/>
        <result property="personName" column="person_name"/>
        <result property="personAge" column="person_age"/>
        <result property="email" column="email"/>
        <result property="delFlag" column="del_flag"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <sql id="selectBizDemoVo">
        select id, person_name, person_age, email, del_flag, create_by, create_time, update_by, update_time from biz_demo
    </sql>

    <select id="listBizDemo" parameterType="BizDemoDO" resultMap="BizDemoResult">
        select id, person_name, person_age, email, del_flag, create_by, create_time, update_by, update_time from biz_demo
    </select>

</mapper>