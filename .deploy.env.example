# ========== 安全确认 ==========
# 必须显式设置为 YES，脚本才会执行（防止误操作）
DEPLOY_CONFIRM=NO

# ========== 本地数据库（数据来源） ==========
LOCAL_DB_HOST=127.0.0.1
LOCAL_DB_PORT=3306
LOCAL_DB_USER=root
LOCAL_DB_PASSWORD=请填写
LOCAL_DB_NAME=GY-EP_local

# ========== 线上数据库（数据目标） ==========
PROD_DB_HOST=127.0.0.1
PROD_DB_PORT=3306
PROD_DB_USER=root
PROD_DB_PASSWORD=请填写
PROD_DB_NAME=GY_EP_PROD

# ========== 目标数据库字符集 ==========
PROD_DB_CHARSET=utf8mb4
PROD_DB_COLLATION=utf8mb4_general_ci

# ========== 代码打包 ==========
# 1: 打包代码；0: 仅做数据库同步
ENABLE_PACKAGE=0
